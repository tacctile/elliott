{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(python *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git pull *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(touch *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf *)",
      "Bash(env)",
      "Bash(printenv)",
      "Bash(export *)"
    ]
  },
  "context": {
    "readOnSessionStart": [
      ".claude/MASTER_CONTEXT.md",
      ".claude/ARCHITECTURE.md",
      ".claude/STATE.yml"
    ]
  }
}
